{
  "name": "dns-dashboard",
  "type": "module",
  "scripts": {
    "dev:server": "bun run --watch server/index.ts",
    "dev:client": "vite",
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "build": "vite build",
    "start": "bun run build && NODE_ENV=production bun run server/index.ts",
    "preview": "bun run build && concurrently \"NODE_ENV=production bun run server/index.ts\" \"vite preview --port 5173\""
  },
  "dependencies": {
    "elysia": "^1.2.25",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/static": "^1.2.0",
    "postgres": "^3.4.5",
    "solid-js": "^1.9.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "terser": "^5.49.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0"
  }
}
